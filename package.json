{
  "name": "geospatial-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Geospatial Intelligence Platform (wildfire early warning) on Cloudflare — MVP for Aragón.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:apply:local": "wrangler d1 migrations apply geospatial-db --local",
    "db:apply:remote": "wrangler d1 migrations apply geospatial-db --remote",
    "twin:build": "node scripts/build-digital-twin.mjs",
    "weather:grid": "node scripts/build-weather-grid.mjs",
    "twin:apply:local": "wrangler d1 execute geospatial-db --local --file tmp/digital-twin.sql",
    "twin:apply:remote": "wrangler d1 execute geospatial-db --remote --file tmp/digital-twin.sql",
    "map:build": "node prototype/build-geojson.mjs",
    "map:deploy": "wrangler pages deploy prototype --project-name geospatial-platform-map --branch main --commit-dirty=true"
  },
  "dependencies": {
    "h3-js": "^4.1.0",
    "omggif": "^1.0.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "workerd@1.20260708.1": true
  }
}
